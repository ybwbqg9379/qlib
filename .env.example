# [FORK] API key template for this fork's data collectors (see FORK.md §5.3).
# Copy to .env (gitignored) and fill in your keys. Collectors auto-load .env
# from the repo root; you can also export these as real environment variables.

# --- Massive (formerly Polygon) — US equities, daily + minute ---------------
# Polygon.io rebranded to Massive on 2025-10-30. Same key works on both hosts.
# Key from the Massive (ex-Polygon) dashboard. POLYGON_API_KEY is accepted as an alias.
MASSIVE_API_KEY=
# Canonical REST host is now api.massive.com. The legacy https://api.polygon.io
# still works through the 2026 migration window — set it here only if needed.
MASSIVE_BASE_URL=https://api.massive.com

# --- Alpha Vantage — US equities + fundamentals, daily + 1min intraday ------
ALPHA_VANTAGE_API_KEY=
